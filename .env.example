# ─── Local dev (native npm run dev) ───────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/location_advisor
REDIS_URL=redis://localhost:6379

# ─── Local dev inside Docker Compose ─────────────────────────────────────────
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/location_advisor
# REDIS_URL=redis://redis:6379

# ─── Railway production ───────────────────────────────────────────────────────
# DATABASE_URL is auto-injected by Supabase / Railway postgres addon
# REDIS_URL is auto-injected by Railway Redis addon
# Set NEXT_PUBLIC_APP_URL to your Railway public domain

# ─── Required in all environments ────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-...
APIFY_API_KEY=apify_api_...
NEXT_PUBLIC_APP_URL=http://localhost:3000
