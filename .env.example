# ─── Local dev (native npm run dev) ───────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/location_advisor
REDIS_URL=redis://localhost:6379

# ─── Local dev inside Docker Compose ─────────────────────────────────────────
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/location_advisor
# REDIS_URL=redis://redis:6379

# ─── Railway production ───────────────────────────────────────────────────────
# DATABASE_URL is auto-injected by Supabase / Railway postgres addon
# REDIS_URL is auto-injected by Railway Redis addon
# Set NEXT_PUBLIC_APP_URL to your Railway public domain

# ─── Required in all environments ────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-...
APIFY_API_KEY=apify_api_...
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Optional scraper overrides ──────────────────────────────────────────────
# Defaults are current Apify Store actor IDs, but keeping them configurable
# avoids code changes if an actor is renamed or replaced.
APIFY_GOOGLE_MAPS_ACTOR_ID=compass/crawler-google-places
APIFY_GOOGLE_MAPS_REVIEWS_ACTOR_ID=compass/Google-Maps-Reviews-Scraper
APIFY_TRIPADVISOR_ACTOR_ID=maxcopell/tripadvisor
APIFY_EVENTBRITE_ACTOR_ID=aitorsm/eventbrite
APIFY_GOOGLE_MAPS_MAX_PLACES_PER_SEARCH=5
APIFY_GOOGLE_MAPS_MAX_TOTAL_PLACES=30
APIFY_GOOGLE_MAPS_MAX_REVIEWS_PER_PLACE=3

# Eventbrite's actor searches by country/city rather than raw lat/lng.
# Set these if you want local event scraping in development.
APIFY_EVENTBRITE_COUNTRY=
APIFY_EVENTBRITE_CITY=

# TripAdvisor's actor searches by named destination rather than raw lat/lng.
# Set this to something like "Vilvoorde, Belgium" to enable it.
APIFY_TRIPADVISOR_LOCATION=
